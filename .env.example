# Environment variables template
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Crypto Payment Addresses (Move these to database in production!)
NEXT_PUBLIC_USDT_BEP20=your_usdt_bep20_address_here
NEXT_PUBLIC_USDT_TRC20=your_usdt_trc20_address_here
NEXT_PUBLIC_USDT_ERC20=your_usdt_erc20_address_here
NEXT_PUBLIC_BTC=your_bitcoin_address_here
NEXT_PUBLIC_ETH=your_ethereum_address_here

# Optional: Rate Limiting (Upstash Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: Error Tracking (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
